{
  "name": "sssk-shooting-results",
  "version": "1.0.0",
  "description": "Visning av skytteresultat",
  "author": "Fredrik Frost",
  "main": "main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/fredrikfrost78/sssk-shooting-results.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "pack:win:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "pack:win:portable:ia32": "npm run build && electron-builder --win portable --ia32 --publish never"
  },
  "type": "module",
  "build": {
    "appId": "se.sssk.shootingresults",
    "productName": "SSSK Shooting Results",
    "extraResources": [
      {
        "from": "server-config.json",
        "to": "server-config.json"
      }
    ],
    "files": [
      "dist/**",
      "main.cjs",
      "preload.cjs",
      "server-config.json",
      "package.json",
      "node_modules/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5"
  }
}
